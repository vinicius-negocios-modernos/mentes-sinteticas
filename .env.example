# ============================================
# Mentes Sinteticas — Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env with real credentials.
#
# Legend:
#   [REQUIRED]       — App will not start without this
#   [CI+LOCAL]       — Needed in both CI pipelines and local dev
#   [LOCAL]          — Needed for local development only
#   [CI-E2E]         — Needed only in CI E2E workflow
#   [OPTIONAL]       — Has sensible defaults; override if needed
# ============================================

# ──────────────────────────────────────────
# 1. Supabase — Database & Auth  [REQUIRED · CI+LOCAL]
# ──────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection (Supabase PostgreSQL)
# Get from: Supabase → Settings → Database → Connection string (URI)
# Pooler (port 6543) for serverless; Direct (port 5432) for migrations
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────
# 2. AI / Gemini  [REQUIRED for LOCAL · OPTIONAL for CI]
# ──────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Model & generation config [OPTIONAL — defaults shown]
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.7
# GEMINI_TOP_K=40
# GEMINI_TOP_P=0.95
# GEMINI_MAX_OUTPUT_TOKENS=8192

# AI Preset — overrides individual generation config values above [OPTIONAL]
# Available: balanced (default), creative, precise
# AI_PRESET=balanced

# ──────────────────────────────────────────
# 3. E2E Testing  [CI-E2E · LOCAL for Playwright]
# ──────────────────────────────────────────
# Test user credentials for Playwright auth setup
# Create a dedicated test user in Supabase Auth
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=test-password-here

# ──────────────────────────────────────────
# 4. Rate Limiting  [OPTIONAL — defaults shown]
# ──────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=20
# RATE_LIMIT_PER_HOUR=200

# ──────────────────────────────────────────
# 5. Token Usage Limits  [OPTIONAL — defaults shown]
# ──────────────────────────────────────────
# Maximum tokens per day per user (default: 500000)
# TOKEN_DAILY_LIMIT=500000

# Maximum tokens per month per user (default: 5000000)
# TOKEN_MONTHLY_LIMIT=5000000

# ──────────────────────────────────────────
# 6. Context Window Optimization  [OPTIONAL — defaults shown]
# ──────────────────────────────────────────
# Max tokens for conversation history per request
# CONTEXT_MAX_HISTORY_TOKENS=30000

# Max messages in history as safety net
# CONTEXT_MAX_MESSAGES=50

# Max messages sent from frontend as history
# NEXT_PUBLIC_MAX_HISTORY_MESSAGES=50

# ──────────────────────────────────────────
# 7. Mind Memory  [OPTIONAL — defaults shown]
# ──────────────────────────────────────────
# Max tokens for mind memories in the context window (default: 2000)
# MEMORY_MAX_TOKENS=2000

# ──────────────────────────────────────────
# 8. Sentry — Error Monitoring  [OPTIONAL]

# ──────────────────────────────────────────
# Get from: Sentry Dashboard → Settings → Projects → Client Keys (DSN)
# Client-side DSN (safe to expose)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Server-side DSN (same DSN, but accessed server-side only)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Build-time upload of source maps [OPTIONAL — builds work without]
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# Traces sample rate (0.0 to 1.0) [OPTIONAL — defaults: prod=0.1, dev=1.0]
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ──────────────────────────────────────────
# 9. App Config  [OPTIONAL]
# ──────────────────────────────────────────
NODE_ENV=development

# App URL — used for metadataBase, OG images, sitemap, robots.txt
# Default: https://mentes-sinteticas.vercel.app
# NEXT_PUBLIC_APP_URL=https://mentes-sinteticas.vercel.app

# ──────────────────────────────────────────
# 10. NextAuth.js  [REQUIRED]
# ──────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_URL=http://localhost:3000
